# Copie ce fichier en ".env" (ou ajoute ces lignes à ton .env existant) et renseigne tes clés.
# Le fichier .env ne doit jamais être commité / partagé.

# Google AI Studio (https://aistudio.google.com/apikey) - structuration du compte rendu
VITE_GEMINI_API_KEY=

# Groq Cloud (https://console.groq.com/keys) - transcription vocale (Whisper) gratuite
VITE_GROQ_API_KEY=

# --- Serveur uniquement (Vercel → Environment Variables, PAS de préfixe VITE_) ---
# Debug live Telegram : crée un bot via @BotFather, écris-lui /start, récupère chat_id
# (https://api.telegram.org/bot<TOKEN>/getUpdates), puis renseigne :
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
